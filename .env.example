# --- Frontend (Vite) — copy to .env.local for local overrides ---
# Public API origin (HTTPS in production). Leave empty to use same-origin /api (needs reverse proxy).
# Example: https://koli-api.onrender.com
VITE_API_BASE_URL=

# Dev only: where Vite proxies /api and /health (default http://127.0.0.1:3001)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# Show small API status pill for beta testers (set to 1 on hosted beta builds)
# VITE_SHOW_API_STATUS=1

# If API has BETA_API_KEY set, send the same value here (still exposed to clients — gate real data with auth later)
# VITE_BETA_API_KEY=

# --- API server (server/index.mjs) — set on the host (Render, Fly, Railway, etc.) ---
# PORT=3001
# NODE_ENV=production
# TRUST_PROXY=1
# Comma-separated list of allowed web app origins (required in production)
# CORS_ORIGIN=https://your-app.vercel.app,https://www.yourdomain.com
# Optional: require x-beta-key header on POST /api/echo (and future routes)
# BETA_API_KEY=
