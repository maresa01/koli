{
  "name": "koli-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev": "vite",
    "dev:api": "npm run dev -w koli-api",
    "dev:full": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "icons:transparent": "node scripts/remove-icons-black-bg.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "puppeteer-core": "^24.40.0",
    "sharp": "^0.34.5",
    "typescript": "~5.7.2",
    "vite": "^6.2.0"
  }
}
